# ================================================================
# LunchDrop — Environment Variables
# Copy ไฟล์นี้เป็น .env แล้วแก้ค่าก่อน deploy
# ================================================================

# Database
DB_NAME=lunchdrop
DB_USER=postgres
DB_PASSWORD=change_me_please_123   # ← เปลี่ยนตรงนี้!

# Admin secret key (ใช้เข้า ?admin=xxx)
ADMIN_KEY=change_this_admin_key    # ← เปลี่ยนตรงนี้!

# Backend
PORT=4000
NODE_ENV=production

# CORS — ใส่ domain จริงถ้า deploy
# FRONTEND_URL=https://lunch.yourcompany.com
FRONTEND_URL=*
